USING: kernel ;
IN: boardwalk-games

: roll-die ( sides -- n )
    "unimplemented" throw ;

: pick-prize ( prizes -- prize )
    "unimplemented" throw ;

: shuffle-deck ( deck -- deck' )
    "unimplemented" throw ;

: deal-hand ( deck n -- hand )
    "unimplemented" throw ;

: play-seeded ( seed quot -- )
    "unimplemented" throw ; inline
