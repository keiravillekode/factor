#!/usr/bin/env bash

# Synopsis:
# Ensure every exercise's exercism-tools/exercism-tools.factor matches
# the canonical lib/exercism-tools/exercism-tools.factor. Run locally
# whenever lib/exercism-tools/exercism-tools.factor changes; CI runs
# this and fails if any exercise was out of date so that the
# regenerated files end up committed.
#
# Exit codes:
#   0 — every exercise was already up to date
#   1 — at least one exercise was updated
#   2 — usage / setup error

set -euo pipefail

src=lib/exercism-tools/exercism-tools.factor

[[ -f "${src}" ]] ||
    { echo >&2 "Run this script from the repo's root directory."; exit 2; }

src_hash=$(md5sum "${src}" | cut -d' ' -f1)

num_updated=0
shopt -s nullglob
for exercise_dir in exercises/concept/*/ exercises/practice/*/; do
    dst_dir="${exercise_dir}exercism-tools"
    dst="${dst_dir}/exercism-tools.factor"
    if [[ -f "${dst}" ]]; then
        dst_hash=$(md5sum "${dst}" | cut -d' ' -f1)
        if [[ "${dst_hash}" != "${src_hash}" ]]; then
            echo "Updating ${dst}"
            cp "${src}" "${dst}"
            num_updated=$((num_updated + 1))
        fi
    else
        echo "Adding ${dst}"
        mkdir -p "${dst_dir}"
        cp "${src}" "${dst}"
        num_updated=$((num_updated + 1))
    fi
done

if (( num_updated > 0 )); then
    echo "${num_updated} exercise(s) updated; commit the changes."
    exit 1
fi

echo "Every exercise is up to date with ${src}."
